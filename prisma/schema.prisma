generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EmailTemplateSettings {
  id               String   @id
  defaultTemplate  String
  topics           Json
  selectedTopicIds Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}